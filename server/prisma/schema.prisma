generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  password  String
  avatar    String   @default("")
  role      String   @default("user")
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  channels      Channel[]
  videos        Video[]
  metas         Meta[]
  assets        Asset[]
  templates     Template[]
  budgetItems   BudgetItem[]
  ideas         Idea[]
  notifications Notification[]
  savedChannels SavedChannel[]
}

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String @default("")
}

model Channel {
  id         Int          @id @default(autoincrement())
  name       String
  color      String       @default("#EF4444")
  icon       String       @default("📺")
  subs       String       @default("0")
  videoCount Int          @default(0)
  views      String       @default("0")
  growth     String       @default("0%")
  userId     Int
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  videos     Video[]
  metas      Meta[]
  assets     Asset[]
  templates  Template[]
  members    TeamMember[]
  ideas      Idea[]
}

model Video {
  id         Int          @id @default(autoincrement())
  title      String
  status     String       @default("idea")
  date       String       @default("")
  priority   String       @default("média")
  duration   String       @default("")
  channelId  Int
  channel    Channel      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId     Int
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  scenes     Scene[]
  checklists Checklist[]
  scripts    Script[]
  seoResults SeoResult[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model Scene {
  id       Int    @id @default(autoincrement())
  type     String @default("content")
  title    String
  duration String @default("")
  notes    String @default("")
  camera   String @default("")
  audio    String @default("")
  color    String @default("#3B82F6")
  thumbnail String @default("")
  order    Int    @default(0)
  videoId  Int
  video    Video  @relation(fields: [videoId], references: [id], onDelete: Cascade)
}

model Checklist {
  id      Int     @id @default(autoincrement())
  label   String
  done    Boolean @default(false)
  videoId Int
  video   Video   @relation(fields: [videoId], references: [id], onDelete: Cascade)
}

model Meta {
  id        Int        @id @default(autoincrement())
  title     String
  userId    Int
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  channelId Int?
  channel   Channel?   @relation(fields: [channelId], references: [id], onDelete: SetNull)
  items     MetaItem[]
  createdAt DateTime   @default(now())
}

model MetaItem {
  id      Int    @id @default(autoincrement())
  label   String
  current Float  @default(0)
  target  Float  @default(0)
  unit    String @default("")
  metaId  Int
  meta    Meta   @relation(fields: [metaId], references: [id], onDelete: Cascade)
}

model TeamMember {
  id       Int       @id @default(autoincrement())
  name     String
  role     String    @default("editor")
  isAdmin   Boolean  @default(false)
  email    String    @default("")
  avatar   String    @default("")
  status   String    @default("offline")
  tasks    Int       @default(0)
  channels Channel[]
}

model Asset {
  id        Int      @id @default(autoincrement())
  name      String
  type      String   @default("thumbnail")
  format    String   @default("")
  size      String   @default("")
  tags      String   @default("")
  fileUrl   String   @default("")
  filePath  String   @default("")
  notes     String   @default("")
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channelId Int?
  channel   Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
}

model Template {
  id        Int      @id @default(autoincrement())
  name      String
  desc      String   @default("")
  episodes  Int      @default(0)
  structure String   @default("")
  color     String   @default("#3B82F6")
  tags      String   @default("")
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channelId Int?
  channel   Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
}

model Notification {
  id        Int      @id @default(autoincrement())
  type      String   @default("info")
  message   String
  read      Boolean  @default(false)
  link      String   @default("")
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model BudgetItem {
  id        Int      @id @default(autoincrement())
  category  String
  desc      String
  value     Float    @default(0)
  type      String   @default("expense")
  month     String   @default("")
  recurring Boolean  @default(false)
  notes     String   @default("")
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Script {
  id        Int      @id @default(autoincrement())
  content   String   @default("")
  version   Int      @default(1)
  label     String   @default("")
  videoId   Int
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SeoResult {
  id          Int      @id @default(autoincrement())
  titles      String   @default("")
  description String   @default("")
  tags        String   @default("")
  score       String   @default("")
  tips        String   @default("")
  videoId     Int
  video       Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model Idea {
  id        Int      @id @default(autoincrement())
  title     String
  content   String   @default("")
  imageUrl  String   @default("")
  tags      String   @default("")
  color     String   @default("#3B82F6")
  pinned    Boolean  @default(false)
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channelId Int?
  channel   Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SystemConfig {
  key   String @id
  value String @default("")
}

model SavedChannel {
  id            Int      @id @default(autoincrement())
  ytChannelId   String
  name          String
  handle        String   @default("")
  thumbnail     String   @default("")
  subscribers   Int      @default(0)
  totalViews    Int      @default(0)
  videoCount    Int      @default(0)
  country       String   @default("")
  score         Int      @default(0)
  tier          String   @default("")
  niche         String   @default("")
  subNiche      String   @default("")
  microNiche    String   @default("")
  avgDuration   String   @default("")
  uploadsPerWeek Float   @default(0)
  bestUploadDay  String  @default("")
  bestUploadHour String  @default("")
  topCountries  String   @default("")
  tags          String   @default("")
  notes         String   @default("")
  modelable     Boolean  @default(false)
  analysisJson  String   @default("")
  userId        Int
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ScriptVersion {
  id        Int      @id @default(autoincrement())
  videoId   Int
  version   Int      @default(1)
  title     String   @default("")
  content   String   @default("")
  sections  String   @default("[]")
  notes     String   @default("")
  createdAt DateTime @default(now())
}
model KeywordResult {
  id          Int      @id @default(autoincrement())
  keyword     String
  score       Int      @default(0)
  volume      String   @default("")
  competition String   @default("")
  avgViews    Int      @default(0)
  topResults  String   @default("[]") // JSON array of top 10 videos
  related     String   @default("[]") // JSON array of related keywords
  niche       String   @default("")
  userId      Int
  createdAt   DateTime @default(now())
}

model DailyIdea {
  id        Int      @id @default(autoincrement())
  title     String
  potential String   @default("medium") // low, medium, high, very_high
  niche     String   @default("")
  reasoning String   @default("")
  tags      String   @default("")
  used      Boolean  @default(false)
  userId    Int
  createdAt DateTime @default(now())
}

model ChannelSnapshot {
  id             Int      @id @default(autoincrement())
  savedChannelId Int
  ytChannelId    String   @default("")
  channelName    String   @default("")
  subscribers    Int      @default(0)
  totalViews     Int      @default(0)
  videoCount     Int      @default(0)
  date           String   @default("") // YYYY-MM-DD
  createdAt      DateTime @default(now())
}

model VideoVelocity {
  id          Int      @id @default(autoincrement())
  ytVideoId   String
  title       String   @default("")
  channelName String   @default("")
  views       Int      @default(0)
  prevViews   Int      @default(0)
  velocity    Float    @default(0) // views per hour
  checkedAt   DateTime @default(now())
}

model CpmReference {
  id          Int      @id @default(autoincrement())
  niche       String
  country     String   @default("US")
  avgCpm      Float    @default(0)
  minCpm      Float    @default(0)
  maxCpm      Float    @default(0)
  lastUpdated DateTime @default(now())
}

model RepurposePiece {
  id          Int      @id @default(autoincrement())
  videoId     Int?
  platform    String   @default("")
  type        String   @default("")
  title       String   @default("")
  content     String   @default("")
  hook        String   @default("")
  status      String   @default("draft") // draft, scheduled, published
  scheduledAt String   @default("")
  userId      Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RevenueEntry {
  id        Int      @id @default(autoincrement())
  channelId Int?
  source    String   @default("adsense") // adsense, affiliate, sponsor, product, membership, merch
  amount    Float    @default(0)
  currency  String   @default("BRL")
  month     String   @default("") // YYYY-MM
  notes     String   @default("")
  userId    Int
  createdAt DateTime @default(now())
}

model OAuthToken {
  id           Int      @id @default(autoincrement())
  userId       Int
  accessToken  String   @default("")
  refreshToken String   @default("")
  expiresAt    String   @default("")
  scope        String   @default("")
  channelId    String   @default("")
  channelName  String   @default("")
  thumbnail    String   @default("")
  subscribers  String   @default("0")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, channelId])
}

model ABTest {
  id           Int      @id @default(autoincrement())
  videoId      String
  type         String   @default("thumbnail") // thumbnail, title, description
  status       String   @default("running") // running, completed, cancelled
  variants     String   @default("[]") // JSON array [{label,value,impressions,clicks,ctr,watchTime}]
  winnerId     Int?
  startedAt    DateTime @default(now())
  endedAt      String   @default("")
  rotationHrs  Int      @default(1)
  userId       Int
  createdAt    DateTime @default(now())
}

model VideoPerformance {
  id            Int      @id @default(autoincrement())
  ytVideoId     String
  title         String   @default("")
  publishedAt   String   @default("")
  impressions   Int      @default(0)
  clicks        Int      @default(0)
  ctr           Float    @default(0)
  avgViewDuration Float  @default(0)
  avgViewPct    Float    @default(0)
  views         Int      @default(0)
  likes         Int      @default(0)
  dislikes      Int      @default(0)
  comments      Int      @default(0)
  shares        Int      @default(0)
  subsGained    Int      @default(0)
  subsLost      Int      @default(0)
  watchTimeMin  Float    @default(0)
  satisfaction  Float    @default(0)
  trafficSources String  @default("{}") // JSON
  devices       String   @default("{}") // JSON {mobile,desktop,tv,tablet}
  countries     String   @default("{}") // JSON
  layer         String   @default("testing") // testing,core,recent,topic,adjacent,viral
  channelId     String   @default("")
  userId        Int
  checkedAt     DateTime @default(now())
}

model CommunityPost {
  id          Int      @id @default(autoincrement())
  type        String   @default("text") // text, poll, image, teaser
  content     String   @default("")
  options     String   @default("[]") // JSON for polls
  status      String   @default("draft") // draft, scheduled, published
  scheduledAt String   @default("")
  videoId     Int?
  channelId   Int?
  userId      Int
  createdAt   DateTime @default(now())
}

model CommentTemplate {
  id       Int    @id @default(autoincrement())
  label    String
  type     String @default("reply") // reply, pinned, first
  content  String @default("")
  userId   Int
}

model UploadStreak {
  id        Int      @id @default(autoincrement())
  userId    Int
  channelId Int?
  date      String   // YYYY-MM-DD
  videoTitle String  @default("")
  type      String   @default("long") // long, short
  createdAt DateTime @default(now())
}

model PlaylistStrategy {
  id          Int    @id @default(autoincrement())
  name        String
  videoIds    String @default("[]") // JSON ordered array of ytVideoIds
  strategy    String @default("") // AI generated strategy
  sessionEst  String @default("") // estimated session duration
  userId      Int
  channelId   Int?
  createdAt   DateTime @default(now())
}

model CatalogAudit {
  id         Int      @id @default(autoincrement())
  ytVideoId  String
  title      String   @default("")
  seoScore   Int      @default(0)
  issues     String   @default("[]") // JSON
  fixes      String   @default("[]") // JSON
  status     String   @default("pending") // pending, fixed, skipped
  userId     Int
  createdAt  DateTime @default(now())
}
