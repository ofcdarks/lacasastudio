generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  password  String
  avatar    String   @default("")
  role      String   @default("user")
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  channels      Channel[]
  videos        Video[]
  metas         Meta[]
  assets        Asset[]
  templates     Template[]
  budgetItems   BudgetItem[]
  ideas         Idea[]
  notifications Notification[]
  savedChannels SavedChannel[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  videoDnas     VideoDna[]

  @@index([email])
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action     String
  resource   String
  resourceId String   @default("")
  details    String   @default("")
  ip         String   @default("")
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String @default("")
}

model Channel {
  id         Int          @id @default(autoincrement())
  name       String
  color      String       @default("#EF4444")
  icon       String       @default("📺")
  subs       String       @default("0")
  videoCount Int          @default(0)
  views      String       @default("0")
  growth     String       @default("0%")
  niche      String       @default("")
  userId     Int
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  videos     Video[]
  metas      Meta[]
  assets     Asset[]
  templates  Template[]
  members    TeamMember[]
  ideas      Idea[]

  @@index([userId])
}

model Video {
  id         Int          @id @default(autoincrement())
  title      String
  status     String       @default("idea")
  date       String       @default("")
  priority   String       @default("média")
  duration   String       @default("")
  channelId  Int
  channel    Channel      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId     Int
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  scenes     Scene[]
  checklists Checklist[]
  scripts    Script[]
  seoResults SeoResult[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([userId, status])
  @@index([channelId, status])
  @@index([userId, channelId])
  @@index([date])
}

model Scene {
  id        Int    @id @default(autoincrement())
  type      String @default("content")
  title     String
  duration  String @default("")
  notes     String @default("")
  camera    String @default("")
  audio     String @default("")
  color     String @default("#3B82F6")
  thumbnail String @default("")
  order     Int    @default(0)
  videoId   Int
  video     Video  @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId, order])
}

model Checklist {
  id      Int     @id @default(autoincrement())
  label   String
  done    Boolean @default(false)
  videoId Int
  video   Video   @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId])
}

model Meta {
  id        Int        @id @default(autoincrement())
  title     String
  userId    Int
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  channelId Int?
  channel   Channel?   @relation(fields: [channelId], references: [id], onDelete: SetNull)
  items     MetaItem[]
  createdAt DateTime   @default(now())

  @@index([userId])
}

model MetaItem {
  id      Int    @id @default(autoincrement())
  label   String
  current Float  @default(0)
  target  Float  @default(0)
  unit    String @default("")
  metaId  Int
  meta    Meta   @relation(fields: [metaId], references: [id], onDelete: Cascade)
}

model TeamMember {
  id       Int       @id @default(autoincrement())
  name     String
  role     String    @default("editor")
  isAdmin  Boolean   @default(false)
  email    String    @default("")
  avatar   String    @default("")
  status   String    @default("offline")
  tasks    Int       @default(0)
  channels Channel[]
}

model Asset {
  folder    String   @default("/")
  id        Int      @id @default(autoincrement())
  name      String
  type      String   @default("thumbnail")
  format    String   @default("")
  size      String   @default("")
  tags      String   @default("")
  fileUrl   String   @default("")
  filePath  String   @default("")
  notes     String   @default("")
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channelId Int?
  channel   Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, type])
  @@index([userId, folder])
}

model Template {
  id        Int      @id @default(autoincrement())
  name      String
  desc      String   @default("")
  episodes  Int      @default(0)
  structure String   @default("")
  color     String   @default("#3B82F6")
  tags      String   @default("")
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channelId Int?
  channel   Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([userId])
}

model Notification {
  id        Int      @id @default(autoincrement())
  type      String   @default("info")
  message   String
  read      Boolean  @default(false)
  link      String   @default("")
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

model BudgetItem {
  id        Int      @id @default(autoincrement())
  category  String
  desc      String
  value     Float    @default(0)
  type      String   @default("expense")
  month     String   @default("")
  recurring Boolean  @default(false)
  notes     String   @default("")
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, month])
}

model Script {
  id        Int      @id @default(autoincrement())
  content   String   @default("")
  version   Int      @default(1)
  label     String   @default("")
  videoId   Int
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([videoId])
}

model SeoResult {
  id          Int      @id @default(autoincrement())
  titles      String   @default("")
  description String   @default("")
  tags        String   @default("")
  score       String   @default("")
  tips        String   @default("")
  videoId     Int
  video       Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([videoId])
}

model Idea {
  id        Int      @id @default(autoincrement())
  title     String
  content   String   @default("")
  imageUrl  String   @default("")
  tags      String   @default("")
  color     String   @default("#3B82F6")
  pinned    Boolean  @default(false)
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channelId Int?
  channel   Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, channelId])
  @@index([userId, pinned])
}

model SystemConfig {
  key   String @id
  value String @default("")
}

model SavedChannel {
  id             Int      @id @default(autoincrement())
  ytChannelId    String
  name           String
  handle         String   @default("")
  thumbnail      String   @default("")
  subscribers    Int      @default(0)
  totalViews     Int      @default(0)
  videoCount     Int      @default(0)
  country        String   @default("")
  score          Int      @default(0)
  tier           String   @default("")
  niche          String   @default("")
  subNiche       String   @default("")
  microNiche     String   @default("")
  avgDuration    String   @default("")
  uploadsPerWeek Float    @default(0)
  bestUploadDay  String   @default("")
  bestUploadHour String   @default("")
  topCountries   String   @default("")
  tags           String   @default("")
  notes          String   @default("")
  modelable      Boolean  @default(false)
  analysisJson   String   @default("")
  userId         Int
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([ytChannelId])
}

model ScriptVersion {
  id        Int      @id @default(autoincrement())
  videoId   Int
  version   Int      @default(1)
  title     String   @default("")
  content   String   @default("")
  sections  String   @default("[]")
  notes     String   @default("")
  createdAt DateTime @default(now())

  @@index([videoId])
}

model KeywordResult {
  id          Int      @id @default(autoincrement())
  keyword     String
  score       Int      @default(0)
  volume      String   @default("")
  competition String   @default("")
  avgViews    Int      @default(0)
  topResults  String   @default("[]")
  related     String   @default("[]")
  niche       String   @default("")
  userId      Int
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([keyword])
}

model DailyIdea {
  id        Int      @id @default(autoincrement())
  title     String
  potential String   @default("medium")
  niche     String   @default("")
  reasoning String   @default("")
  tags      String   @default("")
  used      Boolean  @default(false)
  userId    Int
  createdAt DateTime @default(now())

  @@index([userId])
}

model ChannelSnapshot {
  id             Int      @id @default(autoincrement())
  savedChannelId Int
  ytChannelId    String   @default("")
  channelName    String   @default("")
  subscribers    Int      @default(0)
  totalViews     Int      @default(0)
  videoCount     Int      @default(0)
  date           String   @default("")
  createdAt      DateTime @default(now())

  @@index([savedChannelId])
  @@index([date])
}

model VideoVelocity {
  id          Int      @id @default(autoincrement())
  ytVideoId   String
  title       String   @default("")
  channelName String   @default("")
  views       Int      @default(0)
  prevViews   Int      @default(0)
  velocity    Float    @default(0)
  checkedAt   DateTime @default(now())

  @@index([ytVideoId])
}

model CpmReference {
  id          Int      @id @default(autoincrement())
  niche       String
  country     String   @default("US")
  avgCpm      Float    @default(0)
  minCpm      Float    @default(0)
  maxCpm      Float    @default(0)
  lastUpdated DateTime @default(now())

  @@index([niche, country])
}

model RepurposePiece {
  id          Int      @id @default(autoincrement())
  videoId     Int?
  platform    String   @default("")
  type        String   @default("")
  title       String   @default("")
  content     String   @default("")
  hook        String   @default("")
  status      String   @default("draft")
  scheduledAt String   @default("")
  userId      Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([userId, status])
}

model RevenueEntry {
  id        Int      @id @default(autoincrement())
  channelId Int?
  source    String   @default("adsense")
  amount    Float    @default(0)
  currency  String   @default("BRL")
  month     String   @default("")
  notes     String   @default("")
  userId    Int
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, month])
}

model OAuthToken {
  id           Int      @id @default(autoincrement())
  userId       Int
  accessToken  String   @default("")
  refreshToken String   @default("")
  expiresAt    String   @default("")
  scope        String   @default("")
  channelId    String   @default("")
  channelName  String   @default("")
  thumbnail    String   @default("")
  subscribers  String   @default("0")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, channelId])
  @@index([userId])
}

model ABTest {
  id          Int      @id @default(autoincrement())
  videoId     String
  type        String   @default("thumbnail")
  status      String   @default("running")
  variants    String   @default("[]")
  winnerId    Int?
  startedAt   DateTime @default(now())
  endedAt     String   @default("")
  rotationHrs Int      @default(1)
  userId      Int
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([userId, status])
}

model VideoPerformance {
  id              Int      @id @default(autoincrement())
  ytVideoId       String
  title           String   @default("")
  publishedAt     String   @default("")
  impressions     Int      @default(0)
  clicks          Int      @default(0)
  ctr             Float    @default(0)
  avgViewDuration Float    @default(0)
  avgViewPct      Float    @default(0)
  views           Int      @default(0)
  likes           Int      @default(0)
  dislikes        Int      @default(0)
  comments        Int      @default(0)
  shares          Int      @default(0)
  subsGained      Int      @default(0)
  subsLost        Int      @default(0)
  watchTimeMin    Float    @default(0)
  satisfaction    Float    @default(0)
  trafficSources  String   @default("{}")
  devices         String   @default("{}")
  countries       String   @default("{}")
  layer           String   @default("testing")
  channelId       String   @default("")
  userId          Int
  checkedAt       DateTime @default(now())

  @@index([userId])
  @@index([ytVideoId])
  @@index([userId, layer])
}

model CommunityPost {
  id          Int      @id @default(autoincrement())
  type        String   @default("text")
  content     String   @default("")
  options     String   @default("[]")
  status      String   @default("draft")
  scheduledAt String   @default("")
  videoId     Int?
  channelId   Int?
  userId      Int
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([userId, status])
}

model CommentTemplate {
  id      Int    @id @default(autoincrement())
  label   String
  type    String @default("reply")
  content String @default("")
  userId  Int

  @@index([userId])
}

model UploadStreak {
  id         Int      @id @default(autoincrement())
  userId     Int
  channelId  Int?
  date       String
  videoTitle String   @default("")
  type       String   @default("long")
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([userId, date])
}

model PlaylistStrategy {
  id         Int      @id @default(autoincrement())
  name       String
  videoIds   String   @default("[]")
  strategy   String   @default("")
  sessionEst String   @default("")
  userId     Int
  channelId  Int?
  createdAt  DateTime @default(now())

  @@index([userId])
}

model CatalogAudit {
  id        Int      @id @default(autoincrement())
  ytVideoId String
  title     String   @default("")
  seoScore  Int      @default(0)
  issues    String   @default("[]")
  fixes     String   @default("[]")
  status    String   @default("pending")
  userId    Int
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, status])
}

model UserSetting {
  id     Int    @id @default(autoincrement())
  userId Int
  key    String
  value  String @default("")

  @@unique([userId, key])
  @@index([userId])
}

model ThumbHistory {
  id        Int      @id @default(autoincrement())
  userId    Int
  niche     String   @default("")
  prompt    String   @default("")
  imageUrl  String   @default("")
  title     String   @default("")
  style     String   @default("")
  score     Int      @default(0)
  metadata  String   @default("")
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, niche])
}

model ActionLog {
  id         Int      @id @default(autoincrement())
  userId     Int
  videoId    String   @default("")
  videoTitle String   @default("")
  action     String   @default("")
  category   String   @default("")
  priority   String   @default("")
  completed  Boolean  @default(false)
  completedAt DateTime?
  aiSuggestion String @default("")
  userNote   String   @default("")
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([userId, videoId])
  @@index([videoId])
}

model VideoDna {
  id            Int      @id @default(autoincrement())
  videoTitle    String   @default("")
  videoPath     String   @default("")
  nicho         String   @default("")
  subnicho      String   @default("")
  micronicho    String   @default("")
  estilo        String   @default("")
  qualidade     Int      @default(0)
  analysisJson  String   @default("")
  thumbnailUrl  String   @default("")
  duration      Float    @default(0)
  userId        Int
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  @@index([userId])
}
